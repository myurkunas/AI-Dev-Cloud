# Copy to .env and fill in as needed. All settings are optional.
# The prototype runs with a stubbed response and no secrets by default.

# Anthropic API key. When set (and GENERATION_BACKEND is "auto" or "claude"),
# answers are generated by Claude instead of the stub.
# ANTHROPIC_API_KEY=sk-ant-...

# Model id to use for the Claude backend.
# ANTHROPIC_MODEL=claude-opus-4-8

# Generation backend: auto | stub | claude
# GENERATION_BACKEND=auto

# Retrieval tuning
# TOP_K=3
# SUPPORT_THRESHOLD=1.0

# Path to the corpus file (defaults to data/corpus.json)
# CORPUS_PATH=data/corpus.json
